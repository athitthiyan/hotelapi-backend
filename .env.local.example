# Local-only backend settings. Copy to .env.local for local development.
DATABASE_URL=sqlite:///./hotelapi_local.db
SECRET_KEY=change-this-local-only-secret
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202,http://localhost:4203,http://127.0.0.1:4200,http://127.0.0.1:4201,http://127.0.0.1:4202,http://127.0.0.1:4203

# Leave external integrations as test/no-op values locally.
STRIPE_SECRET_KEY=sk_test_local_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_local_placeholder
STRIPE_WEBHOOK_SECRET=whsec_local_placeholder
RAZORPAY_KEY_ID=rzp_test_local_placeholder
RAZORPAY_KEY_SECRET=rzp_test_local_placeholder
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=noreply@stayvora.local
EMAIL_FROM_NAME=Stayvora Local

# Seed data for local dev only.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=AdminPass123
SEED_ADMIN_NAME=InsightBoard Admin
SEED_PARTNER_EMAIL=partner@example.com
SEED_PARTNER_PASSWORD=PartnerPass123
SEED_PARTNER_NAME=Stayvora Partner
SEED_PARTNER_HOTEL_NAME=Stayvora Local Hotel
