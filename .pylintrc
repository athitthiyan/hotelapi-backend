[MAIN]
persistent = no
init-hook = 'import sys; from pathlib import Path; sys.path.insert(0, str(Path.cwd()))'
ignore = alembic,benchmarks,scripts,tests,__pycache__,.pytest_cache

[MESSAGES CONTROL]
disable =
    duplicate-code,
    import-outside-toplevel,
    invalid-name,
    line-too-long,
    missing-class-docstring,
    missing-function-docstring,
    missing-module-docstring,
    mixed-line-endings,
    multiple-imports,
    no-member,
    not-callable,
    redefined-outer-name,
    reimported,
    singleton-comparison,
    too-many-branches,
    too-few-public-methods,
    too-many-arguments,
    too-many-lines,
    too-many-locals,
    too-many-positional-arguments,
    useless-return,
    wrong-import-order,
    wrong-import-position,
    broad-exception-caught,
    condition-evals-to-constant,
    protected-access,
    too-many-statements,
    unused-argument,
    use-dict-literal

[FORMAT]
max-line-length = 120

[REPORTS]
score = no
