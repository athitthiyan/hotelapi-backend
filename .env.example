# Database — use pgbouncer port 6543 for Supabase (transaction mode)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:6543/postgres

# Supabase (optional — used for admin-level operations)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Stripe (use sk_test_ keys for test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202,http://localhost:4203,http://127.0.0.1:4200,http://127.0.0.1:4201,http://127.0.0.1:4202,http://127.0.0.1:4203,https://stayvora.co.in,https://www.stayvora.co.in,https://payflow-payment-app.vercel.app,https://insightboard-admin.vercel.app,https://partner-portal.vercel.app

# Resend transactional email — get API key at https://resend.com
# Leave blank in development to skip email delivery (graceful no-op)
RESEND_API_KEY=re_...
EMAIL_FROM_ADDRESS=noreply@stayvora.co.in
EMAIL_FROM_NAME=Stayvora

# Seed data (used by scripts/seed.py — do NOT set in production)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=AdminPass123
SEED_ADMIN_NAME=InsightBoard Admin
